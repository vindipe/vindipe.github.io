---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockchainInteractiveLabs from "../components/tutorials/BlockchainInteractiveLabs.astro";
import PillsOfBlockchainInstagram from "../components/tutorials/PillsOfBlockchainInstagram.astro";
---

<BaseLayout
  title="Blockchain 101 | Fundamentals & Interactive Learning | Vincenzo Di Perna"
  description="Interactive blockchain fundamentals: cryptography, peer-to-peer networks, consensus, smart contracts, public and permissioned blockchains, and Pills of Blockchain videos."
  sideBarActiveItemID="tutorials"
>
  <section class="mb-10">
    <div class="flex flex-wrap gap-2 mb-3">
      <span class="badge badge-primary">Blockchain 101</span>
      <span class="badge badge-outline">Fundamentals</span>
      <span class="badge badge-outline">Interactive learning</span>
    </div>

    <h1 class="text-4xl font-bold mb-4">Blockchain 101</h1>

    <p class="text-lg leading-relaxed opacity-90">
      A learning area for understanding blockchain systems through interactive
      explanations, small simulations, visual examples, and practical mental
      models. The goal is to make cryptography, peer-to-peer networks,
      consensus, smart contracts, and blockchain infrastructure easier to
      explore by playing with them.
    </p>
  </section>

  <BlockchainInteractiveLabs />

  <PillsOfBlockchainInstagram />

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-2">Suggest a topic</h2>

    <p class="mb-5 opacity-80">
      This learning area can grow around new blockchain, distributed systems,
      digital assets, Web3, RWA, DeFi, CBDCs, quantum security, benchmarking,
      governance, scalability, and real-world deployment topics.
    </p>

    <div class="card bg-base-100 shadow-md">
      <div class="card-body">
        <h3 class="card-title">What should be explained next?</h3>

        <p>
          Suggest a concept, a practical problem, a tool, or a real-world use
          case that would be useful to explain through a short visual lesson or
          an interactive experiment.
        </p>

        <div class="card-actions justify-end mt-4">
          <a
            class="btn btn-primary"
            href="mailto:vincenzopaolo.diperna@outlook.com?subject=Suggest%20a%20topic%20for%20Blockchain%20101&body=Hi%20Vincenzo%2C%0A%0AI%20would%20like%20to%20suggest%20this%20topic%20for%20Blockchain%20101%3A%0A%0ATopic%3A%20%0AWhy%20it%20would%20be%20useful%3A%20%0A%0AThanks%21"
          >
            Suggest a topic by email
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
