---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-primary-content/20";
---

<ul class="menu grow shrink menu-md overflow-y-auto">
  <li><a class="py-3 text-base font-medium" id="home" href="/">Home</a></li>
  <li><a class="py-3 text-base font-medium" id="projects" href="/projects">Projects</a></li>
  <li><a class="py-3 text-base font-medium" id="research" href="/research">Research</a></li>
  <li><a class="py-3 text-base font-medium" id="tutorials" href="/tutorials">Tutorials</a></li>
  <li><a class="py-3 text-base font-medium" id="cv" href="/cv">CV</a></li>
  <li><a class="py-3 text-base font-medium" id="contact" href="/contact">Contact me</a></li>
</ul>

<script define:vars={{ sideBarActiveItemID: sideBarActiveItemID, activeClass: activeClass }}>
  const activeItemElem = document.getElementById(sideBarActiveItemID);
  activeItemElem && activeItemElem.classList.add(activeClass);
</script>