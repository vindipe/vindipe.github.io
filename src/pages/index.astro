---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { recentWorks } from "../data/recentWorks";

const latestWorks = [...recentWorks]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Vincenzo Di Perna | Blockchain Systems & Digital Assets Engineer"
  description="Personal website of Vincenzo Di Perna: blockchain systems, digital assets, distributed systems, reproducible experimentation, research artifacts, publications, and technical projects."
  sideBarActiveItemID="home"
  ogImage="/og/vincenzo-di-perna-og.png"
>
  <section class="pb-12 mt-5">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-8 items-center">
      <div class="order-2 lg:order-1">
        <h1 class="text-5xl font-bold leading-tight">Vincenzo Di Perna</h1>

        <h2 class="text-3xl py-3 font-bold">
          Blockchain Systems &<br />
          Digital Assets Engineer
        </h2>

        <p class="py-2 text-lg leading-relaxed max-w-3xl">
          I hold a PhD in Blockchain & DLT, working at the intersection of
          distributed systems, blockchain benchmarking, reproducible
          experimentation, protocol evaluation, and digital-asset analytics.<br
          />
          My work focuses on understanding how blockchain technology can reshape today’s
          traditional and digital infrastructures, and how these systems behave under
          realistic evaluation conditions involving networks, workloads, protocols,
          performance, energy use, repeatability, predictability, and economic efficiency.<br
          />
          I am currently interested in how decentralized infrastructures can move
          beyond technical performance to support fairer value distribution and limit
          mechanisms that reinforce wealth concentration.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/projects">
            View Projects and Tools
          </a>

          <a class="btn btn-outline" href="/cv"> View CV </a>

          <a
            class="btn btn-outline"
            href="https://github.com/vindipe"
            target="_blank"
            rel="noopener noreferrer"
          >
            GitHub
          </a>

          <a
            class="btn btn-outline"
            href="https://www.linkedin.com/in/vincenzo-di-perna/"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </div>
      </div>

      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="avatar">
          <div
            class="w-56 rounded-2xl ring ring-primary ring-offset-base-100 ring-offset-4 shadow-xl"
          >
            <img src="/profile.webp" alt="Portrait of Vincenzo Di Perna" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <div
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-5"
    >
      <div>
        <h2 class="text-3xl w-full font-bold">Recent uploads</h2>

        <p class="mt-2 opacity-80">
          Latest research pages, publications, thesis work, artifacts, and technical
outputs added to the site.
        </p>
      </div>
    </div>

    <div class="space-y-4">
      {
        latestWorks.map((work) => (
          <HorizontalCard
            title={work.title}
            img={work.img}
            desc={work.desc}
            url={work.url}
            badge={work.badge}
            target={work.target ?? "_blank"}
          />
        ))
      }
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl w-full font-bold mb-5">More about me</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <h3 class="card-title">Projects and Tools</h3>

          <p>
            Explore selected research artifacts, datasets, software tools, and
            experimental pipelines related to blockchain systems and digital
            assets.
          </p>

          <div class="card-actions justify-end mt-4">
            <a class="btn btn-sm btn-outline" href="/projects">
              View projects and tools
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <h3 class="card-title">Research & publications</h3>

          <p>
            Read more about my publications, research themes, artifacts, and
            work on blockchain benchmarking, performance, energy, and economic
            efficiency.
          </p>

          <div class="card-actions justify-end mt-4">
            <a class="btn btn-sm btn-outline" href="/research">
              View research
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <h3 class="card-title">Blockchain 101</h3>

          <p>
            Interactive blockchain fundamentals, visual explainers, and small
            playable labs on cryptography, peer-to-peer networks, consensus,
            smart contracts, tokens, and distributed infrastructures.
          </p>

          <div class="card-actions justify-end mt-4">
            <a class="btn btn-sm btn-outline" href="/tutorials">
              Start learning
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <h3 class="card-title">CV</h3>

          <p>
            See a compact overview of my background, experience, publications,
            technical skills, and research engineering profile.
          </p>

          <div class="card-actions justify-end mt-4">
            <a class="btn btn-sm btn-outline" href="/cv"> View CV </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12 text-center">
    <h2 class="text-3xl font-bold mb-4">Let's connect</h2>

    <a class="btn btn-primary" href="/contact"> Contact me </a>
  </section>
</BaseLayout>
