---
import { Image } from "astro:assets";

const { title, img, desc, url, badge, tags, target = "_blank" } = Astro.props;

const hasUrl = typeof url === "string" && url.length > 0;
const rel = target === "_blank" ? "noopener noreferrer" : undefined;
---

<div
  class:list={[
    "network-protected rounded-lg bg-base-100 shadow-md transition ease-in-out",
    hasUrl ? "hover:shadow-2xl hover:scale-[102%]" : "",
  ]}
>
  {
    hasUrl ? (
      <a href={url} target={target} rel={rel} class="block">
        <div class="hero-content flex-col md:flex-row">
          {
            img && (
              <Image
                src={img}
                width={750}
                height={422}
                format="webp"
                alt={title}
                class="max-w-full md:max-w-[13rem] rounded-lg"
              />
            )
          }

          <div class="grow w-full">
            <h1 class="text-xl font-bold">
              {title}
              {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
            </h1>

            <p class="py-1 text-1xl">{desc}</p>

            <div class="card-actions justify-end">
              {
                tags &&
                  tags.map((tag) => (
                    <span class="badge badge-outline">{tag}</span>
                  ))
              }
            </div>
          </div>
        </div>
      </a>
    ) : (
      <div class="hero-content flex-col md:flex-row">
        {
          img && (
            <Image
              src={img}
              width={750}
              height={422}
              format="webp"
              alt={title}
              class="max-w-full md:max-w-[13rem] rounded-lg"
            />
          )
        }

        <div class="grow w-full">
          <h1 class="text-xl font-bold">
            {title}
            {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
          </h1>

          <p class="py-1 text-1xl">{desc}</p>

          <div class="card-actions justify-end">
            {
              tags &&
                tags.map((tag) => (
                  <span class="badge badge-outline">{tag}</span>
                ))
            }
          </div>
        </div>
      </div>
    )
  }
</div>