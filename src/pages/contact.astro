---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact me | Vincenzo Di Perna"
  description="Contact Vincenzo Di Perna for research, engineering, blockchain systems, digital assets, and collaboration opportunities."
  sideBarActiveItemID="contact"
>
  <section class="mb-10">
    <h1 class="text-4xl font-bold mb-4">Contact me</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M1.5 6.75A2.25 2.25 0 0 1 3.75 4.5h16.5a2.25 2.25 0 0 1 2.25 2.25v10.5a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 17.25V6.75Zm2.25-.75a.75.75 0 0 0-.75.75v.38l9 5.4 9-5.4v-.38a.75.75 0 0 0-.75-.75H3.75Zm17.25 2.88-8.61 5.17a.75.75 0 0 1-.78 0L3 8.88v8.37c0 .41.34.75.75.75h16.5c.41 0 .75-.34.75-.75V8.88Z"
              ></path>
            </svg>

            Email
          </h3>

          <p>
            For job opportunities, interviews, collaborations, institutional
            projects, consulting requests, or research-related inquiries.
          </p>

          <div class="card-actions justify-end mt-4">
            <a
              class="btn btn-primary"
              href="mailto:vincenzopaolo.diperna@outlook.com"
            >
              Send email
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.32 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.1 20.45H3.54V9H7.1v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.23 0Z"
              ></path>
            </svg>

            LinkedIn
          </h3>

          <p>
            Connect with me for professional updates, research outputs, career
            opportunities, and collaboration discussions.
          </p>

          <div class="card-actions justify-end mt-4">
            <a
              class="btn btn-outline"
              href="https://www.linkedin.com/in/vincenzo-di-perna/"
              target="_blank"
            >
              Open LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-md">
        <div class="card-body">
          <h3 class="card-title flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.15c-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .98-.31 3.18 1.18a11.04 11.04 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.64 1.59.24 2.77.12 3.06.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
              ></path>
            </svg>

            GitHub
          </h3>

          <p>
            Explore my repositories, research artifacts, datasets, and technical
            projects.
          </p>

          <div class="card-actions justify-end mt-4">
            <a
              class="btn btn-outline"
              href="https://github.com/vindipe"
              target="_blank"
            >
              Open GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
