---
const { title, subtitle, date, variant = "primary" } = Astro.props;

const variants = {
  primary: {
    dot: "bg-primary",
    line: "bg-primary",
    badge: "badge-outline",
  },
  warning: {
    dot: "bg-warning",
    line: "bg-warning",
    badge: "badge-warning",
  },
};

const color = variants[variant] ?? variants.primary;
const isPhdThesis = title === "PhD in Blockchain & Distributed Ledger Technology";
---

<div class:list={["flex", isPhdThesis && "phd-thesis-timeline"]}>
  <div class="education__time">
    <span class:list={["w-4 h-4 block rounded-full mt-1", color.dot]}></span>
    <span
      class:list={[
        "education__line block h-full w-[2px] translate-x-[7px]",
        color.line,
      ]}
    ></span>
  </div>

  <div class="experience__data bd-grid px-5 w-full">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2">
      <div>
        <h3 class="font-semibold mb-1">{title}</h3>
        <span class="font-light text-sm">{subtitle}</span>
      </div>

      {
        date && (
          <span class:list={["badge shrink-0 md:ml-4", color.badge]}>
            {date}
          </span>
        )
      }
    </div>

    <div class="my-2 text-justify">
      <slot />

      {
        isPhdThesis && (
          <div class="flex flex-wrap gap-2 mt-3">
            <a
              href="/research/comparing-blockchains"
              class="btn btn-xs btn-outline"
            >
              Open thesis page
            </a>

            <a
              href="/theses/phd-thesis-comparing-blockchains.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-xs btn-outline"
            >
              Open thesis PDF
            </a>

            <a
              href="https://pubblicazioni.unicam.it/handle/11581/502950?mode=complete"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-xs btn-outline"
            >
              UNICAM repository
            </a>
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .phd-thesis-timeline :global(.btn-disabled) {
    display: none;
  }
</style>
