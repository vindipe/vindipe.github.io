---
const posthogToken = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || "https://eu.i.posthog.com";
const analyticsEnabled = import.meta.env.PUBLIC_POSTHOG_ENABLED === "true" && Boolean(posthogToken);

const analyticsConfig = JSON.stringify({
  posthogToken,
  posthogHost,
});
---

{analyticsEnabled && (
  <script
    type="application/json"
    id="site-analytics-config"
    set:html={analyticsConfig}
  ></script>
)}

{analyticsEnabled && (
  <script is:inline>
      (() => {
        const configElement = document.getElementById("site-analytics-config");
        if (!configElement) return;

        const config = JSON.parse(configElement.textContent || "{}");
        const isLocal = ["localhost", "127.0.0.1", "0.0.0.0"].includes(window.location.hostname);
        if (!config.posthogToken || isLocal) return;

        const capture = (eventName, properties = {}) => {
          if (!window.posthog || typeof window.posthog.capture !== "function") return;
          window.posthog.capture(eventName, {
            page_path: window.location.pathname,
            page_title: document.title,
            ...properties,
          });
        };

        window.trackSiteEvent = capture;

        if (!window.__site_posthog_initialized) {
          window.__site_posthog_initialized = true;

          !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);

          window.posthog.init(config.posthogToken, {
            api_host: config.posthogHost,
            defaults: "2026-01-30",
            capture_pageview: "history_change",
            autocapture: false,
            cookieless_mode: "always",
            persistence: "memory",
            disable_session_recording: true,
          });
        }

        if (!window.__site_analytics_events_bound) {
          window.__site_analytics_events_bound = true;

          document.addEventListener("click", (event) => {
            const target = event.target instanceof Element ? event.target : null;
            if (!target) return;

            const explicit = target.closest("[data-analytics-event]");
            if (explicit) {
              capture(explicit.dataset.analyticsEvent, {
                analytics_label: explicit.dataset.analyticsLabel || explicit.textContent?.trim() || undefined,
                analytics_area: explicit.dataset.analyticsArea || undefined,
              });
              return;
            }

            const link = target.closest("a[href]");
            if (!link) return;

            const href = link.getAttribute("href") || "";
            const label = link.getAttribute("aria-label") || link.textContent?.trim() || href;
            const properties = {
              link_url: href,
              link_text: label,
            };

            if (href.startsWith("mailto:")) {
              capture("email_link_click", properties);
              return;
            }

            if (href.includes("github.com/vindipe")) {
              capture("github_link_click", properties);
              return;
            }

            if (href.includes("linkedin.com/in/vincenzo-di-perna")) {
              capture("linkedin_link_click", properties);
              return;
            }

            if (href.includes("doi.org") || href.includes("zenodo")) {
              capture("research_artifact_click", properties);
              return;
            }

            if (href.endsWith(".pdf") || href.includes("/cv/") || href.includes("/theses/")) {
              const eventName = href.includes("/cv/") ? "cv_download_click" : "pdf_download_click";
              capture(eventName, properties);
              return;
            }

            try {
              const url = new URL(href, window.location.href);
              if (url.hostname !== window.location.hostname) {
                capture("outbound_link_click", {
                  ...properties,
                  link_hostname: url.hostname,
                });
              }
            } catch {
              // Ignore malformed or browser-handled links.
            }
          }, { capture: true });
        }
      })();
  </script>
)}
