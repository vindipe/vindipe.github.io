---
const { title, context, howToPlay, observe, nextStep } = Astro.props;
---

<div class="card bg-base-100 shadow-md mb-4">
  <div class="card-body">
    <div class="flex flex-wrap gap-2 items-center mb-2">
      <h3 class="card-title">{title}</h3>
      <span class="badge badge-primary">Guided lab</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-3">
      <div class="rounded-xl bg-base-200 border border-base-300 p-4">
        <p class="font-semibold mb-1">1. Blockchain context</p>
        <p class="text-sm opacity-80">{context}</p>
      </div>

      <div class="rounded-xl bg-base-200 border border-base-300 p-4">
        <p class="font-semibold mb-1">2. How to play</p>
        <p class="text-sm opacity-80">{howToPlay}</p>
      </div>

      <div class="rounded-xl bg-base-200 border border-base-300 p-4">
        <p class="font-semibold mb-1">3. What to observe</p>
        <p class="text-sm opacity-80">{observe}</p>
      </div>

      <div class="rounded-xl bg-base-200 border border-base-300 p-4">
        <p class="font-semibold mb-1">4. Next step</p>
        <p class="text-sm opacity-80">{nextStep}</p>
      </div>
    </div>
  </div>
</div>