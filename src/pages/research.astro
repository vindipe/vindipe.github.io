---
import BaseLayout from "../layouts/BaseLayout.astro";

const publications = [
  {
    title: "Impact of Network Topologies on Blockchain Performance",
    badge: "ACM DEBS '25",
    href: "/research/topology-aware-blockchain-benchmarking",
    desc: "Peer-reviewed research on how network topology affects blockchain performance under controlled, reproducible, and cloud-inspired experimental conditions.",
    tags: [
      "Blockchain benchmarking",
      "Network topology",
      "Lilith",
      "Reproducibility",
    ],
  },
  {
    title:
      "Blockchain Energy Consumption: Unveiling the Impact of Network Topologies",
    badge: "IEEE ICBC '25",
    href: "/research/performance-energy-economic-efficiency",
    desc: "Peer-reviewed research on how network topology, workload type, and blockchain design affect energy consumption and energy per transaction.",
    tags: [
      "Blockchain energy",
      "Network topology",
      "RAPL",
      "Energy per transaction",
    ],
  },
  {
    title:
      "An Entropy-Based Approach to Evaluating the Economic Efficiency of Cryptocurrencies",
    badge: "DLT '25",
    href: "/research/entropy-based-economic-efficiency",
    desc: "Research introducing an entropy-based index to evaluate the economic efficiency of cryptocurrencies through on-chain attributes, user participation, supply dynamics, and transfer activity.",
    tags: [
      "Cryptocurrency efficiency",
      "Shannon entropy",
      "Economic index",
      "Coin Metrics",
    ],
  },
  {
    title: "Dynamic Taxonomy: A Bridge from DeFi to TradFi",
    badge: "CCAF / Working paper",
    href: "/research/dynamic-taxonomy-defi-tradfi",
    desc: "Research developed within the Cambridge Centre for Alternative Finance on a dynamic DeFi taxonomy designed to connect decentralised finance with traditional finance, regulatory perspectives, and the Cambridge DeFi Navigator.",
    tags: ["DeFi", "TradFi", "Taxonomy", "Digital assets", "CCAF"],
  },
];

const artifacts = [
  {
    title: "Lilith – A Topology-Aware Blockchain Benchmarking Framework",
    badge: "Artifact",
    href: "/research/lilith-benchmarking-framework",
    desc: "Public research artifact supporting topology-aware blockchain benchmarking, workload execution, network emulation, and reproducible experimental analysis.",
    tags: ["Framework", "Benchmarking", "Network emulation", "Reproducibility"],
  },
{
  title: "Blockchain Repeatability Dataset for Topology-Aware Benchmarking",
  badge: "Dataset",
  status: "Coming soon",
  disabled: true,
  desc: "Dataset designed to quantify repeatability, variability, and performance predictability across blockchain platforms, workloads, and network topologies. This page will be enabled after the dataset is publicly released.",
  tags: [
    "Dataset",
    "Repeatability",
    "Performance predictability",
    "Experimental analysis",
  ],
},
];
---

<BaseLayout
  title="Research | Vincenzo Di Perna"
  description="Research, publications, artifacts, datasets, thesis work, and research experience by Vincenzo Di Perna."
  sideBarActiveItemID="research"
>
  <section class="mb-10">
    <h1 class="text-4xl font-bold mb-4">Research</h1>

    <p class="text-lg leading-relaxed opacity-90">
      My research focuses on blockchain systems evaluation, distributed
      infrastructures, digital assets, reproducible experimentation,
      network-aware benchmarking, energy and efficiency analysis, and the study
      of performance variability, repeatability, and predictability under
      controlled experimental conditions.
    </p>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-5">Publications</h2>

    <div class="grid gap-5">
      {
        publications.map((item) => (
          <a
            href={item.href}
            class="network-protected card bg-base-100 shadow-md transition ease-in-out hover:shadow-2xl hover:scale-[101%]"
          >
            <article class="card-body">
              <div class="flex flex-wrap gap-2 items-center">
                <h3 class="card-title">{item.title}</h3>
                <span class="badge badge-secondary">{item.badge}</span>
              </div>

              <p>{item.desc}</p>

              <div class="flex flex-wrap gap-2 mt-2">
                {item.tags.map((tag) => (
                  <span class="badge badge-outline">{tag}</span>
                ))}
              </div>

              <div class="card-actions justify-end mt-4">
                <span class="btn btn-sm btn-outline">Open research page</span>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-5">Artifacts &amp; Datasets</h2>

    <div class="grid gap-5">
{
  artifacts.map((item) =>
    item.disabled ? (
      <article class="network-protected card bg-base-100 shadow-md opacity-80">
        <div class="card-body">
          <div class="flex flex-wrap gap-2 items-center">
            <h3 class="card-title">{item.title}</h3>
            <span class="badge badge-secondary">{item.badge}</span>
            <span class="badge badge-warning">{item.status}</span>
          </div>

          <p>{item.desc}</p>

          <div class="flex flex-wrap gap-2 mt-2">
            {item.tags.map((tag) => (
              <span class="badge badge-outline">{tag}</span>
            ))}
          </div>

          <div class="card-actions justify-end mt-4">
            <span class="btn btn-sm btn-disabled">Page not available yet</span>
          </div>
        </div>
      </article>
    ) : (
      <a
        href={item.href}
        class="network-protected card bg-base-100 shadow-md transition ease-in-out hover:shadow-2xl hover:scale-[101%]"
      >
        <article class="card-body">
          <div class="flex flex-wrap gap-2 items-center">
            <h3 class="card-title">{item.title}</h3>
            <span class="badge badge-secondary">{item.badge}</span>
          </div>

          <p>{item.desc}</p>

          <div class="flex flex-wrap gap-2 mt-2">
            {item.tags.map((tag) => (
              <span class="badge badge-outline">{tag}</span>
            ))}
          </div>

          <div class="card-actions justify-end mt-4">
            <span class="btn btn-sm btn-outline">Open artifact page</span>
          </div>
        </article>
      </a>
    )
  )
}
    </div>
  </section>

<section class="mb-12">
  <h2 class="text-3xl font-bold mb-5">Doctoral Thesis</h2>

  <article class="network-protected card bg-base-100 shadow-md opacity-80">
      <article class="card-body">
        <div class="flex flex-wrap gap-2 items-center">
          <h3 class="card-title">
            Comparing Blockchains: Performance, Energy, and Economic
            Efficiencies
          </h3>
          <span class="badge badge-warning">Coming soon</span>
        </div>

<p>
  Doctoral thesis focused on blockchain benchmarking, network topology
  effects, repeatability, performance predictability, energy analysis,
  and economic-efficiency indicators. The dedicated thesis page will be
  enabled after the thesis is publicly available.
</p>

        <div class="flex flex-wrap gap-2 mt-2">
          <span class="badge badge-outline">PhD thesis</span>
          <span class="badge badge-outline">Blockchain systems</span>
          <span class="badge badge-outline">Benchmarking</span>
          <span class="badge badge-outline">Efficiency</span>
        </div>

        <div class="card-actions justify-end mt-4">
          <span class="btn btn-sm btn-disabled">Page not available yet</span>
        </div>
      </div>
    </article>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-5">Research Experience</h2>

    <a
      href="/research/ccaf-experience"
      class="network-protected card bg-base-100 shadow-md transition ease-in-out hover:shadow-2xl hover:scale-[101%]"
    >
      <article class="card-body">
        <div class="flex flex-wrap gap-2 items-center">
          <h3 class="card-title">
            Digital Asset Programme Intern / Digital Asset Research Intern
          </h3>
          <span class="badge badge-secondary">CCAF</span>
        </div>

        <p>
          Research internship experience at the Cambridge Centre for Alternative
          Finance, within the Digital Asset Programme, connected to digital
          assets, DeFi taxonomy, TradFi integration, protocol classification,
          and the Cambridge DeFi Navigator.
        </p>

        <div class="flex flex-wrap gap-2 mt-2">
          <span class="badge badge-outline">Digital Asset Programme</span>
          <span class="badge badge-outline">DeFi</span>
          <span class="badge badge-outline">TradFi</span>
          <span class="badge badge-outline">Taxonomy</span>
          <span class="badge badge-outline">DeFi Navigator</span>
        </div>

        <div class="card-actions justify-end mt-4">
          <span class="btn btn-sm btn-outline">Open experience page</span>
        </div>
      </article>
    </a>
  </section>
</BaseLayout>
