---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Vincenzo Di Perna"
  description="Contact Vincenzo Di Perna for research, engineering, blockchain systems, digital assets, and collaboration opportunities."
  sideBarActiveItemID="contact"
>
  <section class="mb-10">
    <h1 class="text-4xl font-bold mb-4">Contact</h1>

    <p class="text-lg leading-relaxed opacity-90">
      I am open to conversations around research engineering, blockchain systems,
      digital assets, protocol analytics, reproducible experimentation, consulting,
      collaborations, and product-oriented technical projects.
    </p>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-5">Get in touch</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">Email</h3>
          <p>
            For direct messages, collaborations, opportunities, or research-related
            inquiries.
          </p>

          <div class="card-actions justify-end mt-4">
            <a class="btn btn-primary" href="mailto:vincenzopaolo.diperna@outlook.com">
              Send email
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">LinkedIn</h3>
          <p>
            Connect with me for professional updates, research outputs, and career
            opportunities.
          </p>

          <div class="card-actions justify-end mt-4">
            <a
              class="btn btn-outline"
              href="https://www.linkedin.com/in/vincenzo-di-perna/"
              target="_blank"
            >
              Open LinkedIn
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">GitHub</h3>
          <p>
            Explore my repositories, research artifacts, datasets, and technical
            projects.
          </p>

          <div class="card-actions justify-end mt-4">
            <a
              class="btn btn-outline"
              href="https://github.com/vindipe"
              target="_blank"
            >
              Open GitHub
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">Support my work</h3>
          <p>
            I may later add a small support link for independent research,
            open-source artifacts, technical notes, and dashboard-style demos.
          </p>

          <div class="card-actions justify-end mt-4">
            <button class="btn btn-outline btn-disabled">
              Coming soon
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-5">Collaboration areas</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">Blockchain systems</h3>
          <p>
            Benchmarking, protocol evaluation, distributed systems experimentation,
            topology-aware analysis, and reproducibility.
          </p>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">Digital assets & analytics</h3>
          <p>
            Data workflows, DeFi/CBDC-related analysis, protocol indicators,
            dashboards, and digital-asset infrastructure studies.
          </p>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">Research engineering</h3>
          <p>
            Reproducible pipelines, experimental design, datasets, statistical
            analysis, and technical artifacts for research projects.
          </p>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title">Product-oriented projects</h3>
          <p>
            Early-stage software concepts, interactive visualizations, dashboards,
            and technical prototypes connecting systems research with practical use.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
